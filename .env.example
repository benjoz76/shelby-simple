# ===== APTOS API KEY =====
# Dapat dari https://geomi.dev (pilih Testnet, client key)
VITE_APTOS_API_KEY=aptoslabs_your_api_key_here

# ===== SHELBY API KEY =====
# Dapat dari dashboard Shelby atau Discord
VITE_SHELBY_API_KEY=AG-your_shelby_api_key_here

# ===== NETWORK CONFIGURATION =====
VITE_SHELBY_NETWORK=testnet
VITE_SHELBY_RPC=https://api.testnet.shelby.xyz/shelby
VITE_SHELBY_EXPLORER=https://explorer.shelby.xyz

# ===== OPTIONAL CONFIG =====
# VITE_DEFAULT_NETWORK=shelbynet
# VITE_SHELBYNET_APTOS_RPC=https://api.testnet.shelby.xyz/shelby
# VITE_SHELBYNET_SHELBY_RPC=https://api.testnet.shelby.xyz/shelby
